# Frontend env vars (set either Vite or Vercel/Next-style names)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_EVENT_REGISTRATION_WIZARD_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Edge Function environment reference.
# Configure these in your local Edge Function environment and in hosted Supabase secrets.
ALLOWED_ORIGINS=http://localhost:5173
SUPABASE_ENV=local
